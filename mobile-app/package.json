{
  "name": "tok-scrape-dashboard",
  "displayName": "TokScrape Dashboard",
  "version": "0.1.0",
  "description": "Highcharts dashboard for TikTok Shop scrape data stored in Graylog.",
  "main": "www/index.html",
  "scripts": {
    "prepare": "cordova prepare",
    "doctor": "node scripts/check-android-sdk.js",
    "prebuild": "node scripts/check-android-sdk.js",
    "build": "cordova build android",
    "prebuild:release": "node scripts/check-android-sdk.js",
    "build:release": "cordova build android --release",
    "prebuild:preloaded": "node scripts/check-android-sdk.js",
    "build:preloaded": "node scripts/build-preloaded.js",
    "prebuild:preloaded:release": "node scripts/check-android-sdk.js",
    "build:preloaded:release": "RELEASE=1 node scripts/build-preloaded.js",
    "prerun": "node scripts/check-android-sdk.js",
    "run": "cordova run android"
  },
  "private": true,
  "devDependencies": {
    "cordova": "^12.0.0",
    "cordova-android": "^15.0.0",
    "cordova-plugin-splashscreen": "^6.0.2",
    "cordova-plugin-statusbar": "^4.0.0",
    "cordova-plugin-whitelist": "^1.3.5"
  },
  "cordova": {
    "platforms": [
      "android"
    ],
    "plugins": {
      "cordova-plugin-statusbar": {},
      "cordova-plugin-whitelist": {},
      "cordova-plugin-splashscreen": {}
    }
  }
}