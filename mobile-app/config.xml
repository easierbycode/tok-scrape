<?xml version='1.0' encoding='utf-8'?>
<widget id="com.easierbycode.tokscrape" version="0.1.0" xmlns="http://www.w3.org/ns/widgets" xmlns:cdv="http://cordova.apache.org/ns/1.0" xmlns:android="http://schemas.android.com/apk/res/android">
    <name>TokScrape Dashboard</name>
    <description>Highcharts dashboard for TikTok Shop scrape data ingested into Graylog.</description>
    <author email="daniel@easierbycode.com" href="https://easierbycode.com">EasierByCode</author>

    <content src="index.html" />

    <!-- Allow the WebView to navigate/load resources from any HTTPS host the user
         configures as their Graylog endpoint, plus the Highcharts CDN. -->
    <allow-intent href="http://*/*" />
    <allow-intent href="https://*/*" />
    <allow-navigation href="*" />
    <access origin="*" />

    <preference name="DisallowOverscroll" value="true" />
    <preference name="BackgroundColor" value="0xff101012" />
    <preference name="StatusBarOverlaysWebView" value="false" />
    <preference name="StatusBarBackgroundColor" value="#101012" />
    <preference name="StatusBarStyle" value="lightcontent" />
    <preference name="Orientation" value="default" />

    <!-- Splash screen behaviour -->
    <preference name="SplashScreen" value="screen" />
    <preference name="SplashScreenDelay" value="1500" />
    <preference name="AutoHideSplashScreen" value="true" />
    <preference name="FadeSplashScreen" value="true" />
    <preference name="FadeSplashScreenDuration" value="350" />
    <preference name="ShowSplashScreenSpinner" value="false" />
    <preference name="SplashScreenBackgroundColor" value="#101012" />
    <preference name="SplashMaintainAspectRatio" value="true" />

    <platform name="android">
        <preference name="android-minSdkVersion" value="24" />
        <preference name="android-targetSdkVersion" value="36" />
        <preference name="AndroidPersistentFileLocation" value="Internal" />

        <!-- Android 12+ system SplashScreen API (replaces deprecated <splash> tags). -->
        <preference name="AndroidWindowSplashScreenBackground" value="#101012" />
        <preference name="AndroidWindowSplashScreenAnimatedIcon" value="res/screen/android/splash-icon.png" />
        <preference name="AndroidWindowSplashScreenAnimationDuration" value="350" />
        <preference name="AndroidWindowSplashScreenIconBackgroundColor" value="#101012" />

        <!-- Required so the WebView can hit user-supplied Graylog hosts that
             may be plain HTTP (LAN IPs, ngrok subdomains, etc.). -->
        <edit-config file="app/src/main/AndroidManifest.xml" mode="merge" target="/manifest/application">
            <application android:usesCleartextTraffic="true" />
        </edit-config>

        <!-- Launcher icons (LP monogram, generated by scripts/make-icon.py) -->
        <icon density="ldpi" src="res/icon/android/ldpi.png" />
        <icon density="mdpi" src="res/icon/android/mdpi.png" />
        <icon density="hdpi" src="res/icon/android/hdpi.png" />
        <icon density="xhdpi" src="res/icon/android/xhdpi.png" />
        <icon density="xxhdpi" src="res/icon/android/xxhdpi.png" />
        <icon density="xxxhdpi" src="res/icon/android/xxxhdpi.png" />
    </platform>

    <plugin name="cordova-plugin-statusbar" spec="^4.0.0" />
    <plugin name="cordova-plugin-whitelist" spec="^1.3.5" />
    <plugin name="cordova-plugin-splashscreen" spec="^6.0.2" />
</widget>
