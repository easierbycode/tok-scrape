{
  "name": "tok-scrape-mobile",
  "displayName": "TokScrape Mobile",
  "version": "0.1.0",
  "description": "Cordova app that opens TikTok Shop bookmarklet targets in InAppBrowser and runs the matching payload.",
  "main": "www/index.html",
  "scripts": {
    "sync": "node scripts/sync-bookmarklets.js",
    "postinstall": "node scripts/sync-bookmarklets.js",
    "prepare": "node scripts/sync-bookmarklets.js && cordova prepare",
    "prebuild": "node scripts/sync-bookmarklets.js",
    "prerun": "node scripts/sync-bookmarklets.js",
    "build": "cordova build android",
    "build:release": "cordova build android --release",
    "run": "cordova run android"
  },
  "private": true,
  "devDependencies": {
    "cordova": "^12.0.0",
    "cordova-android": "^15.0.0",
    "cordova-plugin-inappbrowser": "^6.0.0",
    "cordova-plugin-statusbar": "^4.0.0",
    "cordova-plugin-whitelist": "^1.3.5"
  },
  "cordova": {
    "platforms": [
      "android"
    ],
    "plugins": {
      "cordova-plugin-statusbar": {},
      "cordova-plugin-whitelist": {},
      "cordova-plugin-inappbrowser": {}
    }
  }
}